#--------------------------------------------------------------------
# ENVIRONMENT
# Set to 'production' on live servers. Use 'development' locally only.
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'http://localhost/qanony/'

# Comma-separated list of allowed hostnames (in addition to baseURL host)
app.allowedHostnames = 'localhost'

# Set to true to force HTTPS on all requests
app.forceGlobalSecureRequests = false

# Content Security Policy
app.CSPEnabled = false

# Locale
app.defaultLocale = 'ar'
app.supportedLocales = 'ar,en'

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

database.default.hostname = 'localhost'
database.default.database = 'qanony'
database.default.username = 'root'
database.default.password = ''
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306
database.default.charset = utf8mb4
database.default.DBCollat = utf8mb4_unicode_ci

#--------------------------------------------------------------------
# ENCRYPTION
# Generate a key with:
#   php -r "echo 'hex2bin:' . bin2hex(random_bytes(32)); echo PHP_EOL;"
#--------------------------------------------------------------------

encryption.key = hex2bin:REPLACE_WITH_64_HEX_CHARS

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

session.driver = 'CodeIgniter\Session\Handlers\DatabaseHandler'
session.savePath = 'ci_sessions'
session.expiration = 7200
session.regenerateDestroy = true

#--------------------------------------------------------------------
# LOGGER
# Threshold: 0=off, 1=emergency…4=warning…9=debug
#--------------------------------------------------------------------

logger.threshold = 4

#--------------------------------------------------------------------
# QANONY AUTH
#--------------------------------------------------------------------

auth.minPasswordLength = 8
auth.maxLoginAttempts = 5
auth.lockoutDuration = 900

#--------------------------------------------------------------------
# UPLOAD
#--------------------------------------------------------------------

# Maximum upload file size in bytes (default: 50 MB)
upload.maxFileSize = 52428800

# Allowed file extensions (comma-separated, no dots)
upload.allowedTypes = 'docx,doc'

#--------------------------------------------------------------------
# CLOUD STORAGE INTEGRATION (optional)
#--------------------------------------------------------------------

# Google Drive Picker — https://console.cloud.google.com/
cloud.googlePickerApiKey =
cloud.googlePickerClientId =
cloud.googlePickerAppId =

# Dropbox Chooser — https://www.dropbox.com/developers/apps
cloud.dropboxAppKey =

# OneDrive File Picker — https://portal.azure.com/
cloud.onedriveClientId =
